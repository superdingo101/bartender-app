// Prisma Schema for Bartending App - Enhanced with Ingredients, Glass Types, Equipment, and Instructions

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - for authentication
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  events    Event[]
  orders    Order[]
  claimedOrders Order[] @relation("OrderClaimedBy")
  
  @@map("users")
}

enum Role {
  CUSTOMER
  BARTENDER
  ADMIN
}

// Event model - represents a bartending event
model Event {
  id          String   @id @default(uuid())
  name        String
  description String?
  date        DateTime
  location    String
  status      EventStatus @default(UPCOMING)
  code        String   @unique // Unique code for customers to join
  hidePrices  Boolean  @default(false) // Hide all prices for this event
  menuOnly    Boolean  @default(false) // Show the customer app as a menu without ordering
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  hostId      String
  host        User     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  drinks      EventDrink[]
  orders      Order[]
  
  @@map("events")
}

enum EventStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

// DrinkCategoryEnum model - master list of drink categories
model DrinkCategoryEnum {
  name        String   @id
  displayName String
  icon        String   @default("🍹")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  drinks      DrinkCategory[]
  
  @@map("drink_category_enums")
}

// Drink model - represents available drinks
model Drink {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // NEW: Optional glass type and equipment
  glassTypeId String?
  glassType   GlassType? @relation(fields: [glassTypeId], references: [id], onDelete: SetNull)
  
  // Relations
  categories  DrinkCategory[]
  events      EventDrink[]
  orders      Order[]
  ingredients DrinkIngredient[]
  equipment   DrinkEquipment[]
  instructions DrinkInstruction[]
  
  @@map("drinks")
}

// Junction table - drinks to categories (supports multiple categories per drink)
model DrinkCategory {
  id              String   @id @default(uuid())
  drinkId         String
  categoryName    String
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  drink           Drink    @relation(fields: [drinkId], references: [id], onDelete: Cascade)
  category        DrinkCategoryEnum @relation(fields: [categoryName], references: [name], onDelete: Cascade)
  
  @@unique([drinkId, categoryName])
  @@map("drink_categories")
}

// Junction table - drinks available at specific events with pricing
model EventDrink {
  id        String   @id @default(uuid())
  price     Float
  available Boolean  @default(true)
  displayOrder Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  drinkId   String
  drink     Drink    @relation(fields: [drinkId], references: [id], onDelete: Cascade)
  
  @@unique([eventId, drinkId])
  @@map("event_drinks")
}

// Order model - customer drink orders
model Order {
  id            String      @id @default(uuid())
  quantity      Int         @default(1)
  status        OrderStatus @default(PENDING)
  customerName  String?
  notes         String?
  totalPrice    Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relations
  customerId    String?
  customer      User?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  claimedById   String?
  claimedBy     User?       @relation("OrderClaimedBy", fields: [claimedById], references: [id], onDelete: SetNull)
  eventId       String
  event         Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  drinkId       String
  drink         Drink       @relation(fields: [drinkId], references: [id], onDelete: Cascade)
  
  @@index([status, claimedById])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// NEW: Ingredient model - enhanced with brand, pricing, and purchase history
model Ingredient {
  id          String   @id @default(uuid())
  name        String   @unique
  type        String   // e.g., "Spirit", "Liqueur", "Juice", "Mixer", "Garnish", "Syrup"
  brand       String?  // Brand name (e.g., "Bacardi", "Grey Goose")
  unit        String   // e.g., "oz", "ml", "bottle", "dash"
  quantity    Float    // Current inventory quantity
  minQuantity Float    // Alert threshold
  bottlePrice Float?   // Standard bottle price
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  drinks          DrinkIngredient[]
  purchaseHistory IngredientPurchase[]
  
  @@map("ingredients")
}

// NEW: Ingredient Purchase History
model IngredientPurchase {
  id           String   @id @default(uuid())
  price        Float
  quantity     Float
  unit         String
  purchaseDate DateTime @default(now())
  supplier     String?
  notes        String?
  
  // Relations
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  
  @@map("ingredient_purchases")
}

// Junction table - ingredients in drinks
model DrinkIngredient {
  id           String     @id @default(uuid())
  quantity     Float
  unit         String
  
  // Relations
  drinkId      String
  drink        Drink      @relation(fields: [drinkId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  
  @@unique([drinkId, ingredientId])
  @@map("drink_ingredients")
}

// NEW: Glass Types
model GlassType {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "Martini Glass", "Rocks Glass", "Highball"
  description String?
  imageUrl    String?
  capacity    Float?   // Capacity in oz
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  drinks      Drink[]
  
  @@map("glass_types")
}

// NEW: Equipment
model Equipment {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "Shaker", "Muddler", "Strainer", "Jigger"
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  drinks      DrinkEquipment[]
  
  @@map("equipment")
}

// NEW: Junction table - equipment needed for drinks
model DrinkEquipment {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  
  // Relations
  drinkId     String
  drink       Drink      @relation(fields: [drinkId], references: [id], onDelete: Cascade)
  equipmentId String
  equipment   Equipment  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  
  @@unique([drinkId, equipmentId])
  @@map("drink_equipment")
}

// NEW: Step-by-step drink instructions
model DrinkInstruction {
  id          String   @id @default(uuid())
  stepNumber  Int      // Order of the instruction
  instruction String   // The actual instruction text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  drinkId     String
  drink       Drink    @relation(fields: [drinkId], references: [id], onDelete: Cascade)
  
  @@unique([drinkId, stepNumber])
  @@map("drink_instructions")
}