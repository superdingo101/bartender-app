# Database Configuration
POSTGRES_USER=bartend
POSTGRES_PASSWORD=secret
POSTGRES_DB=bartending_app

# Backend Configuration
NODE_ENV=development
PORT=5000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS: set CORS_ORIGIN or CLIENT_URL to your public HTTPS origin in production.
# Comma-separate multiple allowed browser origins when needed.
# Leave unset for convenient localhost development defaults.
# CORS_ORIGIN=https://bartender.example.com
# CLIENT_URL=https://bartender.example.com

# Frontend Configuration
# Production behind one HTTPS reverse proxy should normally leave this blank
# so browser calls use same-origin /api, /health, and /socket.io routes.
REACT_APP_API_URL=